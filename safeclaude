#!/bin/bash
# safeclaude -drop-in replacement for `claude` that runs inside a container
#
# Usage:
#   safeclaude                          # start claude in current repo/worktree
#   safeclaude "fix the auth bug"       # start with a prompt
#   safeclaude --resume                 # resume last conversation
#   safeclaude -p "do the thing"        # pass any claude flags
#   safeclaude --persist          # mount ~/.claude for session history
#   safeclaude --shell                    # drop into a bash shell in the container
#   safeclaude --restart                  # fresh container, same image
#   safeclaude --build                  # force rebuild the Docker image
#
# Mount scoping (in priority order):
#   1. SAFECLAUDE_MOUNT=<path>          # explicit mount root
#   2. .safeclaude-mount file           # in any parent dir, contains mount path
#   3. Git repo / worktree root          # just the current repo or worktree
#
# Auth: Claude prompts interactively on first run; credentials persist across containers.

set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
IMAGE="${SAFECLAUDE_IMAGE:-safeclaude}"
CONTAINER_PREFIX="safeclaude"

# --- Load .env if present ---
if [ -f "$SCRIPT_DIR/.env" ]; then
  set -a
  source "$SCRIPT_DIR/.env"
  set +a
fi

# --- Parse safeclaude-specific flags (early, before they're needed) ---
CLAUDE_PASSTHROUGH=()
for arg in "$@"; do
  case "$arg" in
    --persist) SAFECLAUDE_PERSIST_HISTORY=1 ;;
    --shell) SAFECLAUDE_SHELL=1 ;;
    --build) SAFECLAUDE_BUILD=1 ;;
    --restart) SAFECLAUDE_RESTART=1 ;;
    *) CLAUDE_PASSTHROUGH+=("$arg") ;;
  esac
done


# --- Git identity: env override > host git config ---
GIT_USER_NAME="${SAFECLAUDE_GIT_NAME:-$(git config user.name 2>/dev/null || true)}"
GIT_USER_EMAIL="${SAFECLAUDE_GIT_EMAIL:-$(git config user.email 2>/dev/null || true)}"

# --- Detect git context ---
GIT_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || true)"
if [ -z "$GIT_ROOT" ]; then
  echo "error: not inside a git repository"
  echo "safeclaude only runs inside a git repo to limit what Claude can access. cd into one first."
  exit 1
fi

# --- Resolve mount root (priority: env > marker file > git worktrees > repo root) ---
MOUNT_ROOT=""

# 1. Explicit env var
if [ -n "$SAFECLAUDE_MOUNT" ]; then
  MOUNT_ROOT="$SAFECLAUDE_MOUNT"

# 2. Walk up looking for .safeclaude-mount marker file
else
  check_dir="$(pwd)"
  while [ "$check_dir" != "/" ]; do
    if [ -f "$check_dir/.safeclaude-mount" ]; then
      MOUNT_ROOT="$(cat "$check_dir/.safeclaude-mount")"
      # Expand ~ if present
      MOUNT_ROOT="${MOUNT_ROOT/#\~/$HOME}"
      break
    fi
    check_dir="$(dirname "$check_dir")"
  done
fi

# 3. Current repo/worktree root
if [ -z "$MOUNT_ROOT" ]; then
  MOUNT_ROOT="$GIT_ROOT"
fi

# Validate
if [ ! -d "$MOUNT_ROOT" ]; then
  echo "error: mount root does not exist: $MOUNT_ROOT"
  exit 1
fi

# --- Map current host path to container path ---
# Mount at the same absolute path inside the container so Claude session keys
# match between host and container (enables interchangeable claude/safeclaude use).
HOST_CWD="$(pwd)"
CONTAINER_MOUNT="$MOUNT_ROOT"
CONTAINER_CWD="$HOST_CWD"

# --- Build image (force rebuild or if missing) ---
if [ "${SAFECLAUDE_BUILD:-0}" = "1" ]; then
  echo "Building safeclaude image..."
  docker rm -f "${CONTAINER_PREFIX}-$(basename "$MOUNT_ROOT")" 2>/dev/null || true
  docker build --no-cache -t "$IMAGE" "$SCRIPT_DIR"
elif ! docker image inspect "$IMAGE" &>/dev/null; then
  echo "Building safeclaude image..."
  docker build -t "$IMAGE" "$SCRIPT_DIR"
fi

# --- Container name ---
MOUNT_BASENAME="$(basename "$MOUNT_ROOT")"
CONTAINER_NAME="${CONTAINER_PREFIX}-${MOUNT_BASENAME}"

# --- Mounts ---
MOUNTS=(
  -v "$MOUNT_ROOT:$CONTAINER_MOUNT"
)

# If in a worktree, the .git file points to the main repo's .git dir via absolute path.
# Mount it at the same path inside the container so git can resolve it.
GIT_COMMON_DIR="$(cd "$GIT_ROOT" && git rev-parse --git-common-dir 2>/dev/null)"
if [ "$GIT_COMMON_DIR" != ".git" ]; then
  MAIN_GIT_DIR="$(cd "$GIT_ROOT" && cd "$GIT_COMMON_DIR" && pwd)"
  MOUNTS+=(-v "$MAIN_GIT_DIR:$MAIN_GIT_DIR")
fi

# Session history persistence (opt-in via --persist or SAFECLAUDE_PERSIST_HISTORY=1)
# Mounts ~/.claude read-write so sessions, settings, and credentials are shared with host.
if [ "${SAFECLAUDE_PERSIST_HISTORY:-0}" = "1" ]; then
  mkdir -p "$HOME/.claude"
  MOUNTS+=(-v "$HOME/.claude:/home/node/.claude")
elif [ -d "$HOME/.claude" ]; then
  MOUNTS+=(-v "$HOME/.claude:/home/node/.claude-host:ro")
fi

# TODO: Support scoped SSH deploy keys or fine-grained GitHub tokens for
# push access from inside the container, without mounting full host credentials.

# --- Claude args ---
CLAUDE_ARGS=("--dangerously-skip-permissions")
if [ ${#CLAUDE_PASSTHROUGH[@]} -gt 0 ]; then
  CLAUDE_ARGS+=("${CLAUDE_PASSTHROUGH[@]}")
fi

# --- Determine command: claude or bash ---
if [ "${SAFECLAUDE_SHELL:-0}" = "1" ]; then
  CONTAINER_CMD=(bash)
else
  CONTAINER_CMD=(claude "${CLAUDE_ARGS[@]}")
fi

# --- Restart: destroy container, keep image ---
if [ "${SAFECLAUDE_RESTART:-0}" = "1" ]; then
  docker rm -f "$CONTAINER_NAME" 2>/dev/null || true
fi

# --- Reuse existing container if present ---
if docker inspect "$CONTAINER_NAME" &>/dev/null; then
  if [ "$(docker inspect -f '{{.State.Running}}' "$CONTAINER_NAME" 2>/dev/null)" = "true" ]; then
    exec docker exec -it -w "$CONTAINER_CWD" "$CONTAINER_NAME" "${CONTAINER_CMD[@]}"
  else
    docker start "$CONTAINER_NAME" >/dev/null
    exec docker exec -it -w "$CONTAINER_CWD" "$CONTAINER_NAME" "${CONTAINER_CMD[@]}"
  fi
fi

# --- Run ---
exec docker run -it \
  --name "$CONTAINER_NAME" \
  "${MOUNTS[@]}" \
  $SAFECLAUDE_EXTRA_MOUNTS \
  ${GIT_USER_NAME:+-e GIT_USER_NAME="$GIT_USER_NAME"} \
  ${GIT_USER_EMAIL:+-e GIT_USER_EMAIL="$GIT_USER_EMAIL"} \
  ${SAFECLAUDE_HOST_NETWORK:+--add-host=host.docker.internal:host-gateway} \
  -w "$CONTAINER_CWD" \
  "$IMAGE" \
  "${CONTAINER_CMD[@]}"
